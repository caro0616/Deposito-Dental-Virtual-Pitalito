# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Reemplaza <username>, <password> y <cluster-host> con los valores de tu cluster
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>.mongodb.net/?retryWrites=true&w=majority&appName=deposito-dental-cluster
MONGODB_DB_NAME=deposito_dental

# ─── Aplicación ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ─── JWT (autenticación futura) ───────────────────────────────────────────────
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_seguro_de_al_menos_64_caracteres
JWT_EXPIRATION=7d
